dex=False)\r\n","contentType":"embedded","variables":[{"name":"_input1","value":{"portIndex":0,"portName":"inTables","referenceType":"inputPort"}},{"name":"_output1","value":{"arguments":{},"portIndex":0,"portName":"outTables","referenceType":"outputPort"}}]}},"stepReference":{"type":"uri","path":"/dataFlows/steps/ab59f8c4-af9a-4608-a5d5-a8365357bb99"}},"6b178270-33eb-11f1-b597-1b46e255c89a":{"id":"6b178270-33eb-11f1-b597-1b46e255c89a","name":"CARS","nodeType":"table","priority":0,"properties":{"UI_PROP_INPUT_PORT|inTable|0":"|inTable|","UI_PROP_LOCATION":"95.33331298828125 33.333343505859375","UI_PROP_OUTPUT_PORT|outTable|0":"|outTable|"},"tableReference":{"referenceType":"parameter","parameterId":"6b178270-33eb-11f1-b597-1b46e255c89a"}},"7b28f950-33eb-11f1-b597-1b46e255c89a":{"id":"7b28f950-33eb-11f1-b597-1b46e255c89a","name":"ANALYSIS","nodeType":"outputTable","priority":2,"properties":{"UI_PROP_INPUT_PORT|inTable|0":"|inTable|","UI_PROP_LOCATION":"355.33331298828125 49.333343505859375","UI_PROP_OUTPUT_PORT|outTable|0":"|outTable|","usePersistedTableStructure":"false"},"tableReference":{"referenceType":"parameter","parameterId":"7b28f950-33eb-11f1-b597-1b46e255c89a"},"outputTableArguments":{}}},"parameters":{"6b178270-33eb-11f1-b597-1b46e255c89a":{"id":"6b178270-33eb-11f1-b597-1b46e255c89a","name":"CARS","defaultValue":{"table":{"creationTimeStamp":"2026-03-04T20:42:38.55Z","modifiedTimeStamp":"2026-03-04T20:42:38.55Z","version":3,"name":"CARS","providerId":"Compute","dataSourceId":"Compute~fs~ff826f0d-e7e0-4c77-baf2-79b6e4a8c0f6~fs~SASHELP","type":"dataTable","label":"2004 Car Data","attributes":{"bookmarkLength":12,"columnCount":15,"compressionRoutine":"NO","dataTableType":"table","eTag":"\"qnc9pgeu\"","encoding":"us-ascii  ASCII (ANSI)","engine":"V9","id":"CARS","isCas":false,"isReadOnly":true,"libref":"SASHELP","logicalRecordCount":428,"physicalRecordCount":428,"recordLength":152,"rowCount":428}},"source":{"creationTimeStamp":"0001-01-01T00:00:00Z","modifiedT